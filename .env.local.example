# =============================================================================
# 环境变量模板 — 复制为 .env.local 并填入真实值
# cp .env.local.example .env.local   (Unix)
# copy .env.local.example .env.local (Windows)
# =============================================================================

# --- Supabase 项目（Dashboard → Project Settings → API）---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 仅服务端使用，切勿暴露到客户端（Service Role，绕过 RLS）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- 应用 ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase Storage 桶名（上传付款/退款截图时使用，需在 Dashboard 创建）---
NEXT_PUBLIC_STORAGE_BUCKET_PAYMENT=payment-proofs
NEXT_PUBLIC_STORAGE_BUCKET_REFUND=refund-proofs
